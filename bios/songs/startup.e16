.const STARTUP_APU_CH4_BASE, 0xFF2180
.const STARTUP_APU_CH5_BASE, 0xFF21A0

    bra STARTUP_music_module_end

STARTUP_music_play:
    push r0
    mov r0, 1
    storew @STARTUP_LOOP_STATE, r0
    bra STARTUP_music_play_start

STARTUP_music_play_once:
    push r0
    mov r0, 0
    storew @STARTUP_LOOP_STATE, r0
STARTUP_music_play_start:
    call STARTUP_music_load_samples
    mov r0, 0x0023
    storew @STARTUP_APU_CONTROL, r0
    mov r0, 0xFFFF
    storew @STARTUP_APU_MASTER_VOL, r0
    mov r0, 2
    storew @(STARTUP_APU_CH0_BASE + STARTUP_CH_PARAM), r0
    mov r0, 1
    storew @(STARTUP_APU_CH1_BASE + STARTUP_CH_PARAM), r0
    mov r0, 0
    storew @(STARTUP_APU_CH3_BASE + STARTUP_CH_PARAM), r0
    mov r0, STARTUP_WAVETABLE_LENGTH
    storew @(STARTUP_APU_CH4_BASE + STARTUP_CH_LENGTH), r0
    mov r0, 0
    storew @(STARTUP_APU_CH4_BASE + STARTUP_CH_BASE), r0
    mov r0, 6
    storeb @(STARTUP_APU_CH4_BASE + STARTUP_CH_BASE + 2), r0
    mov r0, STARTUP_PCM_LENGTH
    storew @(STARTUP_APU_CH5_BASE + STARTUP_CH_LENGTH), r0
    mov r0, 0x0100
    storew @(STARTUP_APU_CH5_BASE + STARTUP_CH_BASE), r0
    mov r0, 6
    storeb @(STARTUP_APU_CH5_BASE + STARTUP_CH_BASE + 2), r0
    mov r0, 0
    storew @STARTUP_STEP_STATE, r0
    storew @STARTUP_WAIT_STATE, r0
    mov r0, 1
    storew @STARTUP_PLAYING_STATE, r0
    call STARTUP_music_update
    pop r0
    ret

STARTUP_music_load_samples:
    push r0
    push r2
    mov r2, 0
STARTUP_music_load_wavetable_loop:
    loadb r0, @(STARTUP_music_wavetable_data + r2)
    storeb @(STARTUP_WAVETABLE_RAM + r2), r0
    inc r2
    cmp r2, STARTUP_WAVETABLE_LENGTH
    blt STARTUP_music_load_wavetable_loop
    pop r2
    pop r0
    ret

STARTUP_music_stop:
    push r0
    mov r0, 0
    storew @STARTUP_PLAYING_STATE, r0
    storew @(STARTUP_APU_CH0_BASE + STARTUP_CH_CONTROL), r0
    storew @(STARTUP_APU_CH1_BASE + STARTUP_CH_CONTROL), r0
    storew @(STARTUP_APU_CH2_BASE + STARTUP_CH_CONTROL), r0
    storew @(STARTUP_APU_CH3_BASE + STARTUP_CH_CONTROL), r0
    storew @(STARTUP_APU_CH4_BASE + STARTUP_CH_CONTROL), r0
    storew @(STARTUP_APU_CH5_BASE + STARTUP_CH_CONTROL), r0
    pop r0
    ret

STARTUP_music_update:
    push r0
    push r1
    loadw r0, @STARTUP_PLAYING_STATE
    cmp r0, 0
    beq STARTUP_music_update_done
    loadw r0, @STARTUP_WAIT_STATE
    cmp r0, 0
    beq STARTUP_music_update_advance
    dec r0
    storew @STARTUP_WAIT_STATE, r0
    bra STARTUP_music_update_done
STARTUP_music_update_advance:
