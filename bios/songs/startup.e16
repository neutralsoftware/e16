.const STARTUP_APU_CONTROL, 0xFF2000
.const STARTUP_APU_MASTER_VOL, 0xFF2004
.const STARTUP_CH_FREQ, 0x04
.const STARTUP_CH_VOLUME, 0x06
.const STARTUP_CH_PARAM, 0x0E
.const STARTUP_CH_CONTROL, 0x00
.const STARTUP_CH_LENGTH, 0x0A
.const STARTUP_CH_BASE, 0x10
.const STARTUP_WAVETABLE_RAM, 0x060000
.const STARTUP_PCM_RAM, 0x060100
.const STARTUP_WAVETABLE_LENGTH, 32
.const STARTUP_PCM_LENGTH, 0
.const STARTUP_PCM_RATE, 8000
.const STARTUP_STATE_BASE, 0x000150
.const STARTUP_STEP_STATE, STARTUP_STATE_BASE
.const STARTUP_WAIT_STATE, STARTUP_STATE_BASE + 2
.const STARTUP_PLAYING_STATE, STARTUP_STATE_BASE + 4
.const STARTUP_LOOP_STATE, STARTUP_STATE_BASE + 6
.const STARTUP_APU_CH0_BASE, 0xFF2100
.const STARTUP_APU_CH1_BASE, 0xFF2120
